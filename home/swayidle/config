# grace timeout 3 sec, unlock monitor & lock user & off monitor, 
timeout 15 'niri msg action power-off-monitors'
timeout 18 'niri msg action power-on-monitors && swaylock -c ~/.config/swaylock/config && niri msg action power-off-monitors' resume 'niri msg action power-on-monitors'
timeout 60 'systemctl suspend' before-sleep 'swaylock -C ~/.config/swaylock/config'
